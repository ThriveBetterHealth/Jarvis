# =============================================================================
# Jarvis AI — Environment Variables
# Copy this file to .env and replace every CHANGE_ME value before deploying.
# Never commit .env to version control.
#
# Generate secrets quickly:
#   APP_SECRET_KEY  →  openssl rand -hex 32
#   JWT_SECRET_KEY  →  openssl rand -hex 32
#   ENCRYPTION_MASTER_KEY  →  openssl rand -hex 32   (must be exactly 64 hex chars)
#   POSTGRES_PASSWORD / REDIS_PASSWORD  →  openssl rand -base64 24
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
APP_DOMAIN=jarvisapp.cloud

# ── Database (PostgreSQL 16 + pgvector) ───────────────────────────────────────
POSTGRES_DB=jarvis
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
# Host "postgres" = Docker service name — do not change for production Docker setup
DATABASE_URL=postgresql+asyncpg://jarvis:CHANGE_ME_strong_db_password@postgres:5432/jarvis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
# Host "redis" = Docker service name
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AES-256-GCM Encryption ────────────────────────────────────────────────────
# Exactly 64 hex characters (32 bytes).  openssl rand -hex 32
ENCRYPTION_MASTER_KEY=CHANGE_ME_exactly_64_hex_chars

# ── AI Providers ──────────────────────────────────────────────────────────────
# At least ANTHROPIC_API_KEY or OPENAI_API_KEY must be set.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
MANUS_API_KEY=

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG....
SMTP_FROM_EMAIL=jarvis@jarvisapp.cloud
SMTP_FROM_NAME=Jarvis

# ── Frontend (baked into Next.js build at image-build time) ───────────────────
NEXT_PUBLIC_API_URL=https://jarvisapp.cloud
NEXT_PUBLIC_WS_URL=wss://jarvisapp.cloud

# ── File storage ──────────────────────────────────────────────────────────────
FILE_STORAGE_PATH=/app/storage
MAX_FILE_SIZE_MB=50

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AI_PER_MINUTE=20

# ── Monitoring (optional) ─────────────────────────────────────────────────────
# Leave blank to disable Sentry error tracking
SENTRY_DSN=
LOG_LEVEL=INFO
