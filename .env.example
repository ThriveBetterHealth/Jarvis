# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string-at-least-64-chars
APP_DOMAIN=localhost

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_DB=jarvis
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=change-me-strong-db-password
DATABASE_URL=postgresql+asyncpg://jarvis:change-me-strong-db-password@postgres:5432/jarvis

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-at-least-64-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI Providers ────────────────────────────────────────────────────────────
# These are stored encrypted in the DB after first setup; set here only for bootstrap
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
MANUS_API_KEY=...

# ─── Encryption ─────────────────────────────────────────────────────────────
# 32-byte master key for AES-256-GCM (hex encoded)
ENCRYPTION_MASTER_KEY=change-me-64-hex-chars-for-aes256-key

# ─── Email / SMTP ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG....
SMTP_FROM_EMAIL=jarvis@yourdomain.com
SMTP_FROM_NAME=Jarvis

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_WS_URL=wss://yourdomain.com

# ─── Storage ─────────────────────────────────────────────────────────────────
FILE_STORAGE_PATH=/app/storage
MAX_FILE_SIZE_MB=50

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AI_PER_MINUTE=20

# ─── Monitoring ─────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
